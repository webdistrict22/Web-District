{
  "routes": [
    {
      "src": "/sw\\.js",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate"
      },
      "continue": true
    },
    {
      "src": "/manifest\\.webmanifest",
      "headers": {
        "Cache-Control": "no-cache"
      },
      "continue": true
    },
    {
      "src": "/index\\.html",
      "headers": {
        "Cache-Control": "no-cache"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/.*",
      "dest": "/index.html",
      "headers": {
        "Cache-Control": "no-cache"
      }
    }
  ]
}
