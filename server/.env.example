# Runtime environment
NODE_ENV=production
PORT=5000

# MongoDB Atlas
MONGO_URI=

# Authentication: use a long, cryptographically random value.
JWT_SECRET=
JWT_EXPIRES_IN=30d

# Frontend and production CORS origins
CLIENT_URL=https://www.web-district.com
ALLOWED_ORIGINS=https://www.web-district.com,https://web-district.com

# Gmail SMTP
EMAIL_USER=
# Use a Gmail App Password, never the normal account password.
EMAIL_PASS=
OWNER_EMAIL=web.district22@gmail.com
EMAIL_FROM_NAME=Web District
# Keep false in production.
EMAIL_ALLOW_SELF_SIGNED=false

# Cloudinary project-image uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Seed-only values used by: npm run seed
# Remove or rotate seed credentials after the admin account is created.
ADMIN_FULL_NAME=Web District Admin
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_PHONE=

# QA-only values are normally set in the shell, not production runtime config.
API_BASE_URL=https://web-district.onrender.com/api
QA_ADMIN_EMAIL=
QA_ADMIN_PASSWORD=
QA_SEND_TEST_EMAIL=false
QA_TEST_EMAIL=
QA_RUN_WRITE_TESTS=false
QA_ALLOW_PRODUCTION_WRITES=false
